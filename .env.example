# ============================================
# Dubai5 Social Automation — Environment Config
# ============================================

# ── Supabase (Article Source) ─────────────────
SUPABASE_URL=https://qglrvognxdaddoanwqyq.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── LinkedIn ──────────────────────────────────
LINKEDIN_EMAIL=your.email@gmail.com
LINKEDIN_PASSWORD=yourpassword
LINKEDIN_COMPANY_URL=https://www.linkedin.com/company/dubai5-foresight/

# ── X (Twitter) ───────────────────────────────
# Add when account is ready
TWITTER_USERNAME=
TWITTER_PASSWORD=

# ── Facebook ──────────────────────────────────
# Recommended on server: Graph API (no browser / datacenter IP issues with Business Suite)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional: override Graph version (default v21.0)
# FACEBOOK_GRAPH_VERSION=v21.0
#
# Legacy: Meta Business Suite via Puppeteer (set full composer URL)
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=
# Optional: full “Create post” URL (same as in browser). Falls back to FACEBOOK_SUITE_URL or FACEBOOK_ASSET_ID.
# FACEBOOK_COMPOSER_URL=https://business.facebook.com/latest/composer/?asset_id=YOUR_PAGE_ASSET_ID&nav_ref=internal_nav&ref=biz_web_home_create_post&context_ref=HOME
# FACEBOOK_SUITE_URL=   (alias of composer URL)
# FACEBOOK_ASSET_ID=     (numeric Page id for www timeline: profile.php?id=…)
# www posting (setup.js cookies): optional vanity Page URL
# FACEBOOK_WWW_PAGE_URL=https://www.facebook.com/YourPageName
# On VPS: headless Meta composer may not render — use Graph API, or visible Chrome + Xvfb:
#   sudo apt install -y xvfb && xvfb-run -a env FACEBOOK_VISIBLE=true node posters/facebook.js --index=0
# FACEBOOK_VISIBLE=true
FACEBOOK_PAGE_URL=

# ── Instagram ─────────────────────────────────
# Add when account is ready
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Platform Feature Flags ────────────────────
# Set to 'false' to disable a platform
ENABLE_LINKEDIN=true
ENABLE_TWITTER=false
ENABLE_FACEBOOK=false
ENABLE_INSTAGRAM=false

# ── Website to Scrape ─────────────────────────
WEBSITE_URL=https://dubai5.space

# ── Scheduler Timezone ────────────────────────
TIMEZONE=Asia/Dubai

# ── Dashboard Server Port ─────────────────────
DASHBOARD_PORT=3456

# ── Chrome Path (usually auto-detected) ───────
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
