# ============================================
# Dubai5 Social Automation — Environment Config
# ============================================

# ── Supabase (Article Source) ─────────────────
SUPABASE_URL=https://qglrvognxdaddoanwqyq.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── LinkedIn ──────────────────────────────────
LINKEDIN_EMAIL=your.email@gmail.com
LINKEDIN_PASSWORD=yourpassword
LINKEDIN_COMPANY_URL=https://www.linkedin.com/company/dubai5-foresight/

# ── X (Twitter) ───────────────────────────────
# Add when account is ready
TWITTER_USERNAME=
TWITTER_PASSWORD=

# ── Facebook ──────────────────────────────────
# Recommended on server: Graph API (no browser / datacenter IP issues with Business Suite)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional: override Graph version (default v21.0)
# FACEBOOK_GRAPH_VERSION=v21.0
#
# Legacy: Meta Business Suite via Puppeteer (often breaks on AWS headless)
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=
FACEBOOK_PAGE_URL=

# ── Instagram ─────────────────────────────────
# Add when account is ready
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Platform Feature Flags ────────────────────
# Set to 'false' to disable a platform
ENABLE_LINKEDIN=true
ENABLE_TWITTER=false
ENABLE_FACEBOOK=false
ENABLE_INSTAGRAM=false

# ── Website to Scrape ─────────────────────────
WEBSITE_URL=https://dubai5.space

# ── Scheduler Timezone ────────────────────────
TIMEZONE=Asia/Dubai

# ── Dashboard Server Port ─────────────────────
DASHBOARD_PORT=3456

# ── Chrome Path (usually auto-detected) ───────
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
